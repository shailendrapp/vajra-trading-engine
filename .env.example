# ─────────────────────────────────────────────────────────────────────────────
# Argus Trading Engine — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Tradier Paper Trading (sandbox)
TRADIER_API_KEY=your_tradier_sandbox_api_key_here
TRADIER_ACCOUNT_ID=your_tradier_paper_account_id_here

# Anthropic (Claude verdict for BIC alerts — Haiku model)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# FlashAlpha (GEX regime for BIC alerts)
FLASHALPHA_API_KEY=your_flashalpha_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Account
STARTING_EQUITY=50000

# Paths (optional)
DB_PATH=data/trades.db
LOG_DIR=logs/
