# ─────────────────────────────────────────────────────────────────────────────
# Argus Trading Engine — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Tradier Paper Trading (sandbox)
TRADIER_API_KEY=your_tradier_sandbox_api_key_here
TRADIER_ACCOUNT_ID=your_tradier_paper_account_id_here

# FlashAlpha (GEX-based strike selection)
# Sign up free at flashalpha.com — 50 req/day, no credit card
# Argus uses ~8–12 calls/day with 30-min caching
FLASHALPHA_API_KEY=your_flashalpha_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Account
STARTING_EQUITY=50000

# Paths (optional — defaults work fine)
DB_PATH=data/trades.db
LOG_DIR=logs/
